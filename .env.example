# ============== Server ==============
NODE_ENV=development
PORT=3001
PUBLIC_API_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============== Database ==============
DATABASE_URL=postgresql://app:app_password@localhost:5432/crypto_platform

# ============== Redis ==============
REDIS_URL=redis://localhost:6379

# ============== JWT ==============
JWT_ACCESS_SECRET=please-change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=please-change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ============== Encryption ==============
# AES-256-GCM key (base64, 32 bytes). Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# ============== HTX (Huobi) ==============
HTX_WS_URL=wss://api.huobi.pro/ws
HTX_REST_URL=https://api.huobi.pro

# ============== NOWPayments ==============
NOWPAY_API_KEY=
NOWPAY_IPN_SECRET=
NOWPAY_API_URL=https://api.nowpayments.io/v1

# ============== Storage (S3 / R2 / MinIO) ==============
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=crypto-platform
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE=

# ============== Email (SMTP) ==============
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Crypto Platform <noreply@example.com>"

# ============== Telegram Bot ==============
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=

# ============== AI ==============
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ============== Sentry ==============
SENTRY_DSN_SERVER=
SENTRY_DSN_WEB=
SENTRY_DSN_ADMIN=

# ============== WebPush (VAPID) ==============
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# ============== Passkey / WebAuthn ==============
# RP_ID 必须与前端 origin 的 hostname 一致（不含端口）
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Crypto Platform
PASSKEY_ORIGIN=http://localhost:5173

# ============== NOWPayments Mass Payout ==============
# 提现专用 API key + JWT 凭据（与充值 API key 不同）
NOWPAY_PAYOUT_API_KEY=
NOWPAY_PAYOUT_EMAIL=
NOWPAY_PAYOUT_PASSWORD=

# ============== IPQualityScore (反欺诈，可选) ==============
IPQS_API_KEY=

# ============== Frontend (Vite) ==============
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_SENTRY_DSN_WEB=
VITE_SENTRY_DSN_ADMIN=
VITE_FINGERPRINT_API_KEY=
