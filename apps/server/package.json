{
  "name": "@app/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@hono/zod-validator": "^0.4.1",
    "hono": "^4.6.10",
    "drizzle-orm": "^0.36.1",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.5",
    "ioredis": "^5.4.1",
    "bullmq": "^5.21.2",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0",
    "pako": "^2.1.0",
    "nanoid": "^5.0.8",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "decimal.js": "^10.4.3",
    "dayjs": "^1.11.13",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.16",
    "web-push": "^3.6.7",
    "@simplewebauthn/server": "^11.0.0",
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "prom-client": "^15.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pako": "^2.0.3",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.13",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@sentry/node": "^8.40.0"
  }
}
